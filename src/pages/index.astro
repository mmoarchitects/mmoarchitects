---
import Layout from '../layouts/Layout.astro';
import projectsData from '../data/projects.json';

// Presets for styling
const sizePresets = ["size-standard", "size-tall", "size-square", "size-wide"];
const spacePresets = ["space-tight", "space-medium", "space-wide"];

// Helper to determine asset paths (removes /public prefix for Astro)
const getAssetPath = (path: string) => {
  if (!path) return "";
  return path.startsWith("/public") ? path.slice(7) : path;
};

const getProjectAssetPath = (projId: string, fileName: string) => {
  if (!fileName) return "";
  const normalizedFileName = fileName.normalize('NFC');
  if (normalizedFileName.startsWith("/") || normalizedFileName.startsWith("http")) {
    return getAssetPath(normalizedFileName);
  }
  return getAssetPath(`/assets/projects/${projId}/${normalizedFileName}`);
};

// 1. Filter featured projects (mainpjt === "y" or true)
let featured = projectsData.filter(p => p.mainpjt === "y" || p.mainpjt === true);

// 2. If less than 6, fill with random non-featured projects
if (featured.length < 6) {
  const remaining = projectsData.filter(p => !(p.mainpjt === "y" || p.mainpjt === true));
  // Simple deterministic shuffle or pseudo-random at build time
  const shuffled = [...remaining].sort(() => 0.5 - Math.random());
  const needed = 6 - featured.length;
  featured = featured.concat(shuffled.slice(0, needed));
}

// Slice to maximum 6
featured = featured.slice(0, 6);

// 3. Separate the showcase card (the first project)
const topProj = featured[0];
const remainingProjs = featured.slice(1);

// Select thumbnail for showcase card (randomized at build time)
let topThumb = "";
if (topProj.gallery && topProj.gallery.length > 0) {
  const randomIndex = Math.floor(Math.random() * topProj.gallery.length);
  const thumbObj = topProj.gallery[randomIndex];
  topThumb = typeof thumbObj === "object" ? thumbObj.src : thumbObj;
}
const topThumbUrl = getProjectAssetPath(topProj.id, topThumb || topProj.blueprint);
const topSummary = topProj.maintext && topProj.maintext.length > 120 
  ? topProj.maintext.substring(0, 120) + "..." 
  : (topProj.maintext || "");
const topCatString = (Array.isArray(topProj.category) ? topProj.category : [topProj.category]).filter(Boolean).join(', ').toUpperCase();

// 4. Map remaining 5 cards with size and padding styles
const cards = remainingProjs.map((proj, idx) => {
  let selectedThumb = "";
  if (proj.gallery && proj.gallery.length > 0) {
    const randomIndex = Math.floor(Math.random() * proj.gallery.length);
    const thumbObj = proj.gallery[randomIndex];
    selectedThumb = typeof thumbObj === "object" ? thumbObj.src : thumbObj;
  }
  const thumbUrl = getProjectAssetPath(proj.id, selectedThumb || proj.blueprint);
  const summaryText = proj.maintext && proj.maintext.length > 75 
    ? proj.maintext.substring(0, 75) + "..." 
    : (proj.maintext || "");
  const catString = (Array.isArray(proj.category) ? proj.category : [proj.category]).filter(Boolean).join(', ').toUpperCase();

  return {
    ...proj,
    thumbUrl,
    summaryText,
    catString
  };
});

// 5. Apply entropy grid sizes and offsets statically at build time
const guaranteedSpan3Index = Math.floor(Math.random() * cards.length);
let currentColumnSpace = 0;

const styledCards = cards.map((card, index) => {
  let classes = ["project-card"];
  
  if (index === guaranteedSpan3Index) {
    classes.push("colspan-3");
    currentColumnSpace = 0;
  } else {
    const randomSize = sizePresets[Math.floor(Math.random() * sizePresets.length)];
    classes.push(randomSize);

    const randomSpace = spacePresets[Math.floor(Math.random() * spacePresets.length)];
    classes.push(randomSpace);

    // Prevent blank row spaces
    if (currentColumnSpace === 0 && Math.random() > 0.45 && index < cards.length - 1 && (index + 1 !== guaranteedSpan3Index)) {
      classes.push("colspan-2");
      classes.filter(c => c !== "size-tall" && c !== "size-standard");
      classes.push("size-wide");
      currentColumnSpace += 2;
    } else {
      currentColumnSpace += 1;
    }

    if (currentColumnSpace >= 3) {
      currentColumnSpace = 0;
    }
  }

  return {
    ...card,
    className: classes.join(" ")
  };
});
---

<Layout title="MMO ARCHITECTS | 주식회사 엠엠오건축사사무소">
  <section id="hero">
    <h1>Architecture from<br>nothing to <span class="slogan-word-flow" id="slogan-flow"><span class="char-fictio">fictio</span><span class="char-n">n</span><span class="char-onfiction">onfiction.</span></span></h1>
    <p class="hero-sub-ko" id="hero-caption">무(無)의 상태에서 실존하는 질서로 나아가는 건축.</p>
    <a href="#featured-hero-work" class="poetic-scroll-link">Explore MMO ➔</a>
  </section>

  <script>
    function runSloganAnimation() {
      const flow = document.getElementById('slogan-flow');
      const caption = document.getElementById('hero-caption');
      if (!flow || !caption) return;

      // Reset styles to ensure clean replay on page transitions (e.g. Astro View Transitions)
      flow.className = 'slogan-word-flow';
      caption.classList.remove('step-show');

      // Step 1: initial blurry state is default CSS.
      // Step 2: make clear at 0.1s
      setTimeout(() => {
        flow.classList.add('step-clear');
      }, 100);

      // Step 3: collapse "fictio" to leave only "n" at 1.5s (same as original reading window: 1.4s clear)
      setTimeout(() => {
        flow.classList.add('step-collapse');
      }, 1500);

      // Step 4: expand and fade-in "onfiction." at 2.1s (0.6s after collapse starts - 2x faster than previous timing)
      setTimeout(() => {
        flow.classList.add('step-expand');
      }, 2100);

      // Step 5: fade up Korean sub-caption at 3.0s (0.9s after expansion starts)
      setTimeout(() => {
        caption.classList.add('step-show');
      }, 3000);
    }

    // Run on standard load & view transitions
    document.addEventListener('DOMContentLoaded', runSloganAnimation);
    document.addEventListener('astro:page-load', runSloganAnimation);
  </script>

  <section id="featured-hero-work">
    <span class="section-label">Featured Work</span>
    <div class="hero-work-track" id="heroWorkGrid">
      <article class="project-card" data-id={topProj.id}>
        <a href={`/projects/${topProj.id}`}>
          <div class="card-image-slot">
            <div class="photo-layer" style={`background-image: url('${topThumbUrl}');`}></div>
            <div class="blueprint-layer">[VIEW IN PROJECTS]</div>
          </div>
          <h3 class="project-title" style="font-size: 1.8rem; margin-top: 1rem; margin-bottom: 0.5rem;">{topProj.title}</h3>
          <p class="project-summary" style="max-width: 800px; font-size: 1.0rem; line-height: 1.7; color: #444; margin-top: 0.8rem; word-break: keep-all; text-align: justify; display: block; -webkit-line-clamp: unset; overflow: visible;">{topSummary}</p>
          <div class="meta-row" style="margin-top: 15px; margin-bottom: 0;">
            <span class="card-year">{topProj.year}{topProj.status ? ` <span style="margin-left: 4px; font-weight: 400; color: #a3a19b;">(${topProj.status.toUpperCase()})</span>` : ""}</span>
            <span class="card-tag-text">{(topProj.subCategory || "").toUpperCase()} / {topCatString}</span>
          </div>
        </a>
      </article>
    </div>
  </section>

  <section id="philosophy">
    <span class="section-label">Philosophy</span>
    <div class="philosophy-list">
      <div class="philosophy-row-item">
        <span class="philo-num">01</span>
        <h3>Matter</h3>
        <p>문제를 찾는 단계. 재료, 대지, 법적 제약과 같은 물리적 조건(공간이 직면한 핵심 문제)에서 영감과 실험적 질문을 얻습니다.</p>
      </div>
      <div class="philosophy-row-item">
        <span class="philo-num">02</span>
        <h3>Method</h3>
        <p>답을 만드는 단계. 설계·인허가·시공을 잇는 과정 전체를 가장 합리적이고 새로운 방법론으로 정밀하게 해결하려는 태도.</p>
      </div>
      <div class="philosophy-row-item">
        <span class="philo-num">03</span>
        <h3>Order</h3>
        <p>결과로 남는 단계. 도면의 모든 선과 면에 뚜렷한 구조적 이유가 존재하는, 쓰임새 명확하고 비례감이 살아 있는 공간적 물리 질서.</p>
      </div>

      <a href="/about#services" class="integrated-services-bar">
        <div class="service-bar-label">Core Disciplines</div>
        <div class="service-tags-inline">
          <span class="service-inline-item">Architecture</span>
          <span class="service-inline-item">Value-up</span>
          <span class="service-inline-item">Development</span>
          <span class="service-inline-item">Branding</span>
          <span class="service-inline-item">Design Lab</span>
        </div>
        <div class="service-bar-arrow">➔</div>
      </a>
    </div>
  </section>

  <section id="featured-works">
    <span class="section-label">Selected Works</span>
    <div class="entropy-grid-track" id="entropyGrid">
      {styledCards.map(card => (
        <article class={card.className} data-id={card.id}>
          <a href={`/projects/${card.id}`}>
            <div class="card-image-slot">
              <div class="photo-layer" style={`background-image: url('${card.thumbUrl}');`}></div>
              <div class="blueprint-layer">[VIEW IN PROJECTS]</div>
            </div>
            <h3 class="project-title">{card.title}</h3>
            <p class="project-summary">{card.summaryText}</p>
            <div class="meta-row" style="margin-top: 10px; margin-bottom: 0;">
              <span class="card-year">{card.year}{card.status ? ` <span style="margin-left: 4px; font-weight: 400; color: #a3a19b;">(${card.status.toUpperCase()})</span>` : ""}</span>
              <span class="card-tag-text">{(card.subCategory || "").toUpperCase()} / {card.catString}</span>
            </div>
          </a>
        </article>
      ))}
      <div class="grid-footer" id="gridFooter">
        <a href="/projects" class="poetic-scroll-link">View All Projects ➔</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Page specific styles */
  section { 
    padding: 8rem 3rem 4rem 3rem; 
    max-width: 1400px; 
    margin: 0 auto;
    min-height: 75vh;
    display: flex; flex-direction: column; justify-content: center;
  }
  .section-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.2em; color: #aaa; margin-bottom: 3rem; display: block; }

  /* HERO SCREEN WITH ANIMATION */
  #hero { min-height: 85vh; text-align: center; align-items: center; justify-content: center; padding-top: 4rem; }
  #hero h1 { font-size: 3.8rem; font-weight: 400; letter-spacing: -0.02em; line-height: 1.25; margin-bottom: 1.5rem; }
  
  .slogan-word-flow {
    display: inline-flex;
    align-items: baseline;
    vertical-align: bottom;
  }
  .char-fictio {
    display: inline-block;
    vertical-align: bottom;
    overflow: hidden;
    white-space: nowrap;
    max-width: 8ch;
    opacity: 0.2;
    filter: blur(12px);
    transition: max-width 1.35s cubic-bezier(0.25, 1, 0.5, 1), 
                opacity 1.05s cubic-bezier(0.25, 1, 0.5, 1), 
                filter 1.05s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .char-n {
    display: inline-block;
    vertical-align: bottom;
    opacity: 0.2;
    filter: blur(12px);
    transition: opacity 1.05s cubic-bezier(0.25, 1, 0.5, 1), 
                filter 1.05s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .char-onfiction {
    display: inline-block;
    vertical-align: bottom;
    overflow: hidden;
    white-space: nowrap;
    max-width: 0;
    opacity: 0;
    transition: max-width 1.35s cubic-bezier(0.25, 1, 0.5, 1), 
                opacity 1.05s cubic-bezier(0.25, 1, 0.5, 1);
  }

  /* Animation states triggered by JS classes */
  .slogan-word-flow.step-clear .char-fictio,
  .slogan-word-flow.step-clear .char-n {
    opacity: 1;
    filter: blur(0);
  }
  .slogan-word-flow.step-collapse .char-fictio {
    max-width: 0;
    opacity: 0;
    transition: max-width 0.68s cubic-bezier(0.25, 1, 0.5, 1), 
                opacity 0.53s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .slogan-word-flow.step-expand .char-onfiction {
    max-width: 12ch;
    opacity: 1;
  }

  .hero-sub-ko {
    font-size: 1.05rem;
    font-weight: 400;
    color: #888;
    margin-top: 0;
    margin-bottom: 3.2rem;
    letter-spacing: -0.01em;
    line-height: 1.6;
    word-break: keep-all;
    
    /* Animation base */
    opacity: 0;
    transform: translateY(15px);
    transition: opacity 1.2s cubic-bezier(0.25, 1, 0.5, 1), 
                transform 1.2s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .hero-sub-ko.step-show {
    opacity: 1;
    transform: translateY(0);
  }
  .poetic-scroll-link {
    font-size: 0.85rem; letter-spacing: 0.05em; font-weight: 600; padding-bottom: 0.4rem; border-bottom: 1px solid #000;
    transition: all 0.55s cubic-bezier(0.25, 1, 0.5, 1); cursor: pointer;
  }
  .poetic-scroll-link:hover { color: #666; border-bottom: 1px solid #666; padding-right: 0.5rem; }
  
  /* STANDALONE SHOWCASE WORK */
  #featured-hero-work {
    min-height: auto;
    padding-bottom: 6rem;
  }
  .hero-work-track {
    width: 100%;
  }
  .hero-work-track .project-card {
    width: 100%;
  }
  .hero-work-track .card-image-slot {
    aspect-ratio: 21/9;
  }

  /* PHILOSOPHY */
  #philosophy {
    padding-top: 4rem;
    padding-bottom: 4rem;
    min-height: auto;
  }
  .philosophy-list {
    display: flex;
    flex-direction: column;
    width: 100%;
    border-top: 1px solid #e5e4e0;
  }
  .philosophy-row-item {
    display: grid;
    grid-template-columns: 80px 180px 1fr;
    align-items: baseline;
    padding: 1.6rem 1rem;
    width: 100%;
    transition: background-color 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .philosophy-row-item:hover {
    background-color: rgba(26, 26, 26, 0.01);
  }
  .philo-num {
    font-family: Georgia, serif;
    font-style: italic;
    font-size: 1.6rem;
    color: #b5b4ad;
    line-height: 1;
  }
  .philosophy-row-item h3 {
    font-size: 1.25rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    line-height: 1;
  }
  .philosophy-row-item p {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.65;
    word-break: keep-all;
    margin: 0;
    text-align: justify;
  }
  .integrated-services-bar {
    border-bottom: 1px solid #e5e4e0;
    padding: 1.6rem 1rem; 
    display: grid;
    grid-template-columns: 260px 1fr auto;
    align-items: center;
    background-color: transparent;
    transition: background-color 0.6s cubic-bezier(0.25, 1, 0.5, 1), 
                padding-left 0.6s cubic-bezier(0.25, 1, 0.5, 1), 
                padding-right 0.6s cubic-bezier(0.25, 1, 0.5, 1),
                border-bottom-color 0.6s cubic-bezier(0.25, 1, 0.5, 1);
    cursor: pointer;
    width: 100%;
  }
  .integrated-services-bar:hover {
    background-color: rgba(26, 26, 26, 0.015); 
    padding-left: 1.8rem; padding-right: 1.8rem;
    border-bottom-color: #1a1a1a;
  }
  .service-bar-label { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.15em; color: #8c8a85; text-transform: uppercase; }
  .service-tags-inline { display: flex; gap: 2.5rem; align-items: center; }
  .service-inline-item { font-size: 0.85rem; font-weight: 600; letter-spacing: 0.05em; color: #666; text-transform: uppercase; }
  .integrated-services-bar:hover .service-inline-item { color: #1a1a1a; }
  .service-bar-arrow { 
    font-size: 1rem; font-weight: 300; color: #8c8a85; 
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1), color 0.4s; 
    text-align: right;
  }
  .integrated-services-bar:hover .service-bar-arrow { 
    transform: translateX(8px); 
    color: #1a1a1a; 
  }

  /* SELECTED WORKS (ENTROPY GRID MATRIX) */
  #featured-works { max-width: 1500px; padding-top: 4rem; }
  .entropy-grid-track {
    display: grid; grid-template-columns: repeat(3, 1fr); grid-auto-flow: dense;
    column-gap: 5%; row-gap: 130px; align-items: start; width: 100%;
  }
  .project-card { display: flex; flex-direction: column; box-sizing: border-box; cursor: pointer; }
  
  .card-image-slot { width: 100%; background-color: #dfded9; margin-bottom: 24px; position: relative; overflow: hidden; }
  .photo-layer, .blueprint-layer {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-size: cover; background-position: center;
    transition: opacity 0.55s cubic-bezier(0.25, 1, 0.5, 1), transform 0.55s cubic-bezier(0.25, 1, 0.5, 1), filter 0.55s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .blueprint-layer { 
    opacity: 0; 
    background-color: rgba(245, 244, 240, 0.35); 
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    color: #000; 
    font-size: 0.85rem; 
    font-weight: 600;
    letter-spacing: 0.15em;
    display: flex; 
    align-items: center; 
    justify-content: center; 
    z-index: 3;
  }
  .project-card:hover .photo-layer { 
    transform: scale(1.03); 
    filter: blur(2px) brightness(0.9); 
  }
  .project-card:hover .blueprint-layer { 
    opacity: 1; 
  }

  .size-standard .card-image-slot { aspect-ratio: 4/3; }
  .size-tall .card-image-slot { aspect-ratio: 3/4; }
  .size-square .card-image-slot { aspect-ratio: 1/1; }
  .size-wide .card-image-slot { aspect-ratio: 16/10; }
  
  .colspan-3 { grid-column: span 3 !important; }
  .colspan-3 .card-image-slot { aspect-ratio: 21/9; }
  .colspan-2 { grid-column: span 2; }
  .colspan-2.size-wide .card-image-slot { aspect-ratio: 16/9; }
  
  .space-tight { margin-top: -20px; }
  .space-medium { margin-top: 20px; }
  .space-wide { margin-top: 45px; }

  .meta-row { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px; font-size: 10px; letter-spacing: 0.15em; color: #8c8a85; font-weight: 600; text-transform: uppercase; }
  .project-title { font-size: 1.25rem; font-weight: 500; margin: 0 0 10px 0; letter-spacing: -0.02em; }
  .project-summary { font-size: 0.9rem; line-height: 1.6; color: #666460; font-weight: 300; text-align: justify; }

  .grid-footer { 
    grid-column: 3; align-self: end; display: flex; justify-content: flex-end; 
    margin-top: 40px; padding-bottom: 10px; 
  }

  /* Responsive styling overrides */
  @media (max-width: 900px) {
    .philosophy-row-item {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      padding: 1.5rem 1rem;
    }
    .philosophy-row-item h3 {
      font-size: 1.1rem;
    }
    .integrated-services-bar {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
      padding: 1.5rem 1rem;
    }
    .service-tags-inline {
      flex-wrap: wrap;
      gap: 1rem 2rem;
    }
  }
  @media (max-width: 1100px) {
    section { padding-top: 8rem; }
    .entropy-grid-track { grid-template-columns: 1fr; }
    .integrated-services-bar { flex-direction: column; align-items: flex-start; gap: 1.5rem; padding: 1.5rem 1rem; margin-top: 2rem; }
    .service-tags-inline { flex-wrap: wrap; gap: 1rem 2rem; }
    .space-tight, .space-medium, .space-wide { margin-top: 0; }
    .project-card.colspan-2, .project-card.colspan-3 { grid-column: span 1 !important; }
    .grid-footer { grid-column: 1; justify-content: center; align-self: center; margin-top: 40px; }
    .hero-work-track .card-image-slot { aspect-ratio: 16/10; }
    .hero-sub-ko { font-size: 0.95rem; margin-bottom: 2rem; }
    #hero h1 { font-size: 2.5rem; }
  }
</style>
