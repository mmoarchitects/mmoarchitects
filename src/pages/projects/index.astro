---
import Layout from '../../layouts/Layout.astro';
import projectsData from '../../data/projects.json';

// Size and padding presets for asymmetry
const sizePresets = ["size-standard", "size-tall", "size-square", "size-wide"];
const spacePresets = ["space-tight", "space-medium", "space-wide"];

// Helper to determine asset paths (removes /public prefix for Astro)
const getAssetPath = (path: string) => {
  if (!path) return "";
  return path.startsWith("/public") ? path.slice(7) : path;
};

const getProjectAssetPath = (projId: string, fileName: string) => {
  if (!fileName) return "";
  const normalizedFileName = fileName.normalize('NFC');
  let path = "";
  if (normalizedFileName.startsWith("/") || normalizedFileName.startsWith("http")) {
    path = getAssetPath(normalizedFileName);
  } else {
    path = getAssetPath(`/assets/projects/${projId}/${normalizedFileName}`);
  }
  return path ? `${path}?v=2` : "";
};

const getVimeoEmbedUrl = (vimeoInput: any) => {
  if (!vimeoInput) return "";
  let videoId = vimeoInput.toString().trim();
  const reg = /vimeo\.com\/(?:video\/)?([0-9]+)/;
  const match = videoId.match(reg);
  if (match && match[1]) {
    videoId = match[1];
  }
  return `https://player.vimeo.com/video/${videoId}?background=1&autoplay=1&loop=1&byline=0&title=0&muted=1`;
};

// Normalize tags for class names
const normalizeTag = (str: string) => {
  if (!str) return "";
  return str.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9\-]/g, '').trim();
};

// Gather all unique categories for the filter bar
const categorySet = new Set<string>();
projectsData.forEach(proj => {
  if (proj.category) {
    const cats = Array.isArray(proj.category) ? proj.category : [proj.category];
    cats.forEach(c => {
      if (c) categorySet.add(c.trim());
    });
  }
});

// Custom preferred sort order for categories (Architecture 1st, Interior 2nd, others alphabetical)
const preferredOrder = ["Architecture", "Interior"];

const categories = Array.from(categorySet).sort((a, b) => {
  const indexA = preferredOrder.indexOf(a);
  const indexB = preferredOrder.indexOf(b);
  if (indexA !== -1 && indexB !== -1) return indexA - indexB;
  if (indexA !== -1) return -1;
  if (indexB !== -1) return 1;
  return a.localeCompare(b);
});

// Prepare project cards
let currentColumnSpace = 0;
const projects = projectsData.map((proj, index) => {
  const isVimeo = !!proj.vimeo;
  let thumbUrl = "";
  let vimeoUrl = "";

  if (isVimeo) {
    vimeoUrl = getVimeoEmbedUrl(proj.vimeo);
  } else {
    let selectedThumb = "";
    if (proj.gallery && proj.gallery.length > 0) {
      const randomIndex = Math.floor(Math.random() * proj.gallery.length);
      const thumbObj = proj.gallery[randomIndex];
      selectedThumb = typeof thumbObj === "object" ? thumbObj.src : thumbObj;
    }
    thumbUrl = getProjectAssetPath(proj.id, selectedThumb || proj.blueprint || "");
  }

  // Determine size and space presets
  const randomSize = sizePresets[Math.floor(Math.random() * sizePresets.length)];
  const randomSpace = spacePresets[Math.floor(Math.random() * spacePresets.length)];
  
  let classes = ["project-card", randomSize, randomSpace];

  // Prevent blank row spaces
  if (currentColumnSpace === 0 && Math.random() > 0.45 && index < projectsData.length - 1) {
    classes.push("colspan-2");
    classes = classes.filter(c => c !== "size-tall" && c !== "size-standard");
    classes.push("size-wide");
    currentColumnSpace += 2;
  } else {
    currentColumnSpace += 1;
  }

  if (currentColumnSpace >= 3) {
    currentColumnSpace = 0;
  }

  // Join categories into tag classes for filtering
  const cats = (Array.isArray(proj.category) ? proj.category : [proj.category]).filter(Boolean) as string[];
  const normalizedTags = cats.map(c => normalizeTag(c)).join(" ");
  const catDisplayString = cats.join(", ").toUpperCase();

  const summaryText = proj.maintext && proj.maintext.length > 75 
    ? proj.maintext.substring(0, 75) + "..." 
    : (proj.maintext || "");

  return {
    ...proj,
    isVimeo,
    thumbUrl,
    vimeoUrl,
    className: classes.join(" "),
    normalizedTags,
    catDisplayString,
    summaryText
  };
});
---

<Layout title="MMO ARCHITECTS — PROJECTS" activeTab="projects">
  <main class="portfolio-container">
    <aside class="filter-sidebar">
      <div class="filter-sticky">
        <div class="mobile-filter-header" id="mobileFilterHeader">
          <span>* CATEGORY<span class="selected-category-label">: ALL</span> <span class="toggle-arrow">➔</span></span>
        </div>
        <ul class="filter-list" id="filterList">
          <li class="filter-item active" data-filter="all">ALL</li>
          {categories.map(cat => (
            <li class="filter-item" data-filter={normalizeTag(cat)}>{cat.toUpperCase()}</li>
          ))}
        </ul>
      </div>
    </aside>

    <section class="masonry-infinite-wrapper" id="infiniteWrapper">
      <div class="grid-track" id="gridTrack">
        {projects.map(proj => (
          <article class={proj.className} data-id={proj.id} data-tags={proj.normalizedTags}>
            <a href={`/projects/${proj.id}`}>
              <div class="card-image-slot">
                {proj.isVimeo ? (
                  <div class="photo-layer" style="background: #000;">
                    <iframe 
                      src={proj.vimeoUrl} 
                      style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0; pointer-events: none;" 
                      frameborder="0" 
                      allow="autoplay; fullscreen" 
                      allowfullscreen>
                    </iframe>
                  </div>
                ) : (
                  <div class="photo-layer" style={`background-image: url('${proj.thumbUrl}');`}></div>
                )}
                <div class="blueprint-layer">[VIEW THIS PROJECT]</div>
              </div>
              <h3 class="project-title">{proj.title}</h3>
              <p class="project-summary">{proj.summaryText}</p>
              <div class="meta-row" style="margin-top: 10px; margin-bottom: 0;">
                <span class="card-year">{proj.year}{proj.status && <span style="margin-left: 4px; font-weight: 400; color: #a3a19b;">({proj.status.toUpperCase()})</span>}</span>
                <span class="card-tag-text">{(proj.subCategory || "").toUpperCase()} / {proj.catDisplayString}</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>
  </main>
</Layout>

<script>
  // Client-side filtering and sidebar reveal logic
  document.addEventListener("astro:page-load", () => {
    const track = document.getElementById("gridTrack");
    const wrapper = document.getElementById("infiniteWrapper");
    
    let trackHeight = 0;
    const updateTrackHeight = () => {
      if (track) {
        trackHeight = track.getBoundingClientRect().height;
      }
    };

    let applyLayout = () => {};
    let updateClone = () => {};

    // 0. Shuffle and apply random layout to project cards (runs on client for true page-load randomness)
    if (track) {
      const cards = Array.from(track.querySelectorAll(".project-card")) as HTMLElement[];
      
      // Shuffle the cards array randomly once
      cards.sort(() => Math.random() - 0.5);
      
      // Layout helper presets
      const sizePresets = ["size-standard", "size-tall", "size-square", "size-wide"];
      const spacePresets = ["space-tight", "space-medium", "space-wide"];
      const layoutClasses = [
        "size-standard", "size-tall", "size-square", "size-wide",
        "space-tight", "space-medium", "space-wide",
        "colspan-2", "colspan-3"
      ];
      
      const normalPatterns = [
        { name: "1,1,1", spans: [1, 1, 1], cardsNeeded: 3 },
        { name: "1,2", spans: [1, 2], cardsNeeded: 2 },
        { name: "2,1", spans: [2, 1], cardsNeeded: 2 },
        { name: "3", spans: [3], cardsNeeded: 1 }
      ];

      const spacerPatterns = [
        { name: "1,spacer1,1", spans: [1, "spacer1", 1], cardsNeeded: 2 },
        { name: "1,1,spacer1", spans: [1, 1, "spacer1"], cardsNeeded: 2 },
        { name: "spacer1,1,1", spans: ["spacer1", 1, 1], cardsNeeded: 2 },
        { name: "1,spacer2", spans: [1, "spacer2"], cardsNeeded: 1 },
        { name: "spacer2,1", spans: ["spacer2", 1], cardsNeeded: 1 },
        { name: "spacer1,2", spans: ["spacer1", 2], cardsNeeded: 1 },
        { name: "2,spacer1", spans: [2, "spacer1"], cardsNeeded: 1 }
      ];

      updateClone = () => {
        if (track && wrapper) {
          const existingClone = document.getElementById("gridTrackClone");
          if (existingClone) {
            existingClone.remove();
          }
          
          const cloneTrack = track.cloneNode(true) as HTMLElement;
          cloneTrack.id = "gridTrackClone";
          cloneTrack.querySelectorAll("[id]").forEach(el => el.removeAttribute("id"));
          wrapper.appendChild(cloneTrack);
        }
      };

      applyLayout = () => {
        // Remove existing spacers
        track.querySelectorAll(".grid-spacer").forEach(el => el.remove());

        // Get currently visible project cards (among the original cards)
        const visibleCards = cards.filter(card => card.style.display !== "none");

        let cardIndex = 0;
        let rowCount = 0;
        const elementsToAppend: HTMLElement[] = [];

        while (cardIndex < visibleCards.length) {
          const cardsLeft = visibleCards.length - cardIndex;
          let chosenPattern: any = null;

          // Approx. 30% chance for spacer row on the projects page (skip first row to keep top neat)
          const wantSpacer = (Math.random() < 0.3) && (rowCount > 0);

          if (wantSpacer) {
            const validSpacers = spacerPatterns.filter(p => p.cardsNeeded <= cardsLeft);
            if (validSpacers.length > 0) {
              chosenPattern = validSpacers[Math.floor(Math.random() * validSpacers.length)];
            }
          }

          if (!chosenPattern) {
            const validNormals = normalPatterns.filter(p => p.cardsNeeded <= cardsLeft);
            if (validNormals.length > 0) {
              chosenPattern = validNormals[Math.floor(Math.random() * validNormals.length)];
            } else {
              chosenPattern = { name: "fallback", spans: Array(cardsLeft).fill(1), cardsNeeded: cardsLeft };
            }
          }

          chosenPattern.spans.forEach((spanVal: any) => {
            if (typeof spanVal === "string" && spanVal.startsWith("spacer")) {
              const spacer = document.createElement("div");
              spacer.className = "grid-spacer";
              if (spanVal === "spacer1") {
                spacer.classList.add("colspan-1");
              } else if (spanVal === "spacer2") {
                spacer.classList.add("colspan-2");
              }
              elementsToAppend.push(spacer);
            } else {
              const card = visibleCards[cardIndex++];
              card.classList.remove(...layoutClasses);

              const randomSize = sizePresets[Math.floor(Math.random() * sizePresets.length)];
              const randomSpace = spacePresets[Math.floor(Math.random() * spacePresets.length)];
              card.classList.add(randomSize, randomSpace);

              if (spanVal === 2) {
                card.classList.add("colspan-2");
                card.classList.remove("size-tall", "size-standard");
                card.classList.add("size-wide");
              } else if (spanVal === 3) {
                card.classList.add("colspan-3");
                card.classList.remove("size-tall", "size-standard", "size-square");
                card.classList.add("size-wide");
              }
              elementsToAppend.push(card);
            }
          });

          rowCount++;
        }

        // Clear and append in correct sequence
        track.innerHTML = "";
        elementsToAppend.forEach(el => track.appendChild(el));

        // Re-append hidden cards to keep them in DOM for filtering
        cards.forEach(card => {
          if (card.style.display === "none") {
            track.appendChild(card);
          }
        });

        // Recreate the clone
        updateClone();

        // Recalculate track height after layout update
        setTimeout(updateTrackHeight, 50);
      };

      // Run initial layout
      applyLayout();
    }

    // 1. Sidebar Reveal
    const sidebar = document.querySelector(".filter-sidebar");
    if (sidebar) {
      sidebar.classList.add("init-reveal");
      setTimeout(() => {
        sidebar.classList.remove("init-reveal");
      }, 1000);
    }

    // 2. Mobile Filter List Toggle
    const mobileHeader = document.getElementById("mobileFilterHeader");
    const filterListUl = document.getElementById("filterList");
    if (mobileHeader && filterListUl) {
      mobileHeader.addEventListener("click", () => {
        const isOpen = filterListUl.classList.toggle("is-open");
        const arrow = mobileHeader.querySelector(".toggle-arrow");
        if (arrow) {
          arrow.innerText = isOpen ? "▼" : "➔";
        }
      });
    }

    // 3. Filter Handler
    if (filterListUl && track) {
      filterListUl.addEventListener("click", (e) => {
        const item = (e.target as HTMLElement).closest(".filter-item");
        if (!item) return;

        document.querySelectorAll(".filter-item").forEach(el => el.classList.remove("active"));
        item.classList.add("active");

        const filterValue = item.getAttribute("data-filter");
        
        // Filter only original cards currently in track
        const cards = Array.from(track.querySelectorAll(".project-card")) as HTMLElement[];

        cards.forEach(card => {
          if (filterValue === "all") {
            card.style.display = "flex";
          } else {
            const cardTags = card.getAttribute("data-tags") || "";
            if (cardTags.split(" ").includes(filterValue || "")) {
              card.style.display = "flex";
            } else {
              card.style.display = "none";
            }
          }
        });

        // Reapply grid layout dynamically
        applyLayout();

        // Update selected label and collapse list on mobile/tablet
        const labelText = item.textContent || "ALL";
        const labelSpan = mobileHeader?.querySelector(".selected-category-label");
        if (labelSpan) {
          labelSpan.textContent = `: ${labelText}`;
        }
        if (window.innerWidth <= 1100) {
          filterListUl.classList.remove("is-open");
          const arrow = mobileHeader?.querySelector(".toggle-arrow");
          if (arrow) {
            (arrow as HTMLElement).innerText = "➔";
          }
        }
      });
    }

    // 4. Infinite Loop Magazine Scroll
    if (track && wrapper) {
      // Remove any existing clone first (e.g. from previous Astro page loads to prevent stacking)
      const existingClone = document.getElementById("gridTrackClone");
      if (existingClone) {
        existingClone.remove();
      }
      
      const cloneTrack = track.cloneNode(true) as HTMLElement;
      cloneTrack.id = "gridTrackClone";
      // Clear IDs in the clone to avoid duplicate IDs in the DOM
      cloneTrack.querySelectorAll("[id]").forEach(el => el.removeAttribute("id"));
      wrapper.appendChild(cloneTrack);
      
      // Calculate initial height
      updateTrackHeight();
      
      window.addEventListener("resize", updateTrackHeight);
      
      // Update when images inside the track finish loading
      track.querySelectorAll("img").forEach(img => {
        if (img.complete) {
          updateTrackHeight();
        } else {
          img.addEventListener("load", updateTrackHeight);
        }
      });
      
      const handleInfiniteScroll = () => {
        const currentScroll = window.pageYOffset || document.documentElement.scrollTop;
        const rowGapOffset = 140; // match row-gap of grid track
        
        if (trackHeight > 0) {
          if (currentScroll >= (trackHeight + rowGapOffset)) {
            window.scrollTo(0, currentScroll - (trackHeight + rowGapOffset));
          } else if (currentScroll <= 0) {
            window.scrollTo(0, (trackHeight + rowGapOffset) + currentScroll);
          }
        }
      };
      
      window.addEventListener("scroll", handleInfiniteScroll);
      
      // Clean up event listeners on page transition
      document.addEventListener("astro:before-swap", () => {
        window.removeEventListener("resize", updateTrackHeight);
        window.removeEventListener("scroll", handleInfiniteScroll);
      }, { once: true });
    }
  });
</script>

<style>
  /* Page specific styles */
  .portfolio-container { 
    display: flex; flex-direction: row; width: 100%; max-width: 1900px; margin: 0 auto; 
    padding: 180px 4% 8rem 4%; box-sizing: border-box; 
  }
  
  /* Filter Sidebar styling - PC version (width > 1100px) */
  .filter-sidebar { 
    width: 70px; 
    height: 100vh; 
    position: fixed; 
    top: 0; 
    left: 4%; 
    z-index: 990; 
    background: transparent; 
    display: flex; 
    align-items: flex-start; 
    padding-top: 180px; 
    box-sizing: border-box; 
    transition: width 0.6s cubic-bezier(0.25, 1, 0.5, 1); 
  }
  .filter-sticky { 
    opacity: 0; 
    visibility: hidden; 
    width: 140px; 
    transition: opacity 0.4s ease, visibility 0.4s; 
  }
  .filter-sidebar:hover, .filter-sidebar.init-reveal { 
    width: 220px; 
  }
  .filter-sidebar:hover .filter-sticky, .filter-sidebar.init-reveal .filter-sticky { 
    opacity: 1; 
    visibility: visible; 
  }
  
  .filter-list { list-style: none; display: flex; flex-direction: column; gap: 1.2rem; }
  .filter-item { 
    font-size: 0.75rem; font-weight: 600; letter-spacing: 0.15em; color: #888; cursor: pointer; 
    transition: color 0.4s, padding-left 0.4s; position: relative; padding-left: 0;
  }
  .filter-item:hover, .filter-item.active { color: #1a1a1a; }
  .filter-item::before { 
    content: ""; position: absolute; left: 0; top: 50%; width: 0; height: 1px; 
    background-color: #1a1a1a; transform: translateY(-50%); transition: width 0.4s; 
  }
  .filter-item.active { padding-left: 14px; }
  .filter-item.active::before { width: 8px; }

  /* Infinite Scroll and Grid Track */
  .masonry-infinite-wrapper { 
    flex-grow: 1; 
    margin-left: 70px; 
    transition: margin-left 0.6s cubic-bezier(0.25, 1, 0.5, 1); 
    position: relative; 
  }
  .filter-sidebar:hover + .masonry-infinite-wrapper, 
  .filter-sidebar.init-reveal + .masonry-infinite-wrapper { 
    margin-left: 220px; 
  }
  
  .grid-track { 
    display: grid; grid-template-columns: repeat(3, 1fr); grid-auto-flow: dense; 
    column-gap: 6.5%; row-gap: 140px; align-items: start; width: 100%; 
  }
  #gridTrackClone { margin-top: 140px; }
  .project-card { display: flex; flex-direction: column; cursor: pointer; box-sizing: border-box; }
  .project-card a { display: flex; flex-direction: column; width: 100%; }
  
  .card-image-slot { width: 100%; background-color: #dfded9; margin-bottom: 24px; position: relative; overflow: hidden; }
  .photo-layer, .blueprint-layer {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-size: cover; background-position: center;
    transition: opacity 0.55s cubic-bezier(0.25, 1, 0.5, 1), transform 0.55s cubic-bezier(0.25, 1, 0.5, 1), filter 0.55s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .blueprint-layer { 
    opacity: 0; 
    background-color: rgba(245, 244, 240, 0.35); 
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    color: #000; 
    font-size: 0.85rem; 
    font-weight: 600;
    letter-spacing: 0.15em;
    display: flex; 
    align-items: center; 
    justify-content: center; 
    z-index: 3;
  }
  .project-card:hover .photo-layer { 
    transform: scale(1.03); 
    filter: blur(2px) brightness(0.9); 
  }
  .project-card:hover .blueprint-layer { 
    opacity: 1; 
  }

  .size-standard .card-image-slot { aspect-ratio: 4/3; }
  .size-tall .card-image-slot { aspect-ratio: 3/4; }
  .size-square .card-image-slot { aspect-ratio: 1/1; }
  .size-wide .card-image-slot { aspect-ratio: 16/10; }
  
  .colspan-3 { grid-column: span 3 !important; }
  .colspan-3 .card-image-slot { aspect-ratio: 21/9; }
  .colspan-2 { grid-column: span 2; }
  .colspan-2.size-wide .card-image-slot { aspect-ratio: 16/9; }
  
  .grid-spacer {
    pointer-events: none;
    visibility: hidden;
  }
  .grid-spacer.colspan-2 {
    grid-column: span 2;
  }
  
  .space-tight { margin-top: -20px; }
  .space-medium { margin-top: 20px; }
  .space-wide { margin-top: 45px; }

  .meta-row { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px; font-size: 10px; letter-spacing: 0.15em; color: #8c8a85; font-weight: 600; text-transform: uppercase; }
  .project-title { font-size: 1.25rem; font-weight: 500; margin: 0 0 10px 0; letter-spacing: -0.02em; }
  .project-summary { font-size: 0.9rem; line-height: 1.6; color: #666460; font-weight: 300; text-align: justify; white-space: pre-line; }

  /* GNB Scroll margin */
  .project-card {
    scroll-margin-top: 120px;
    scroll-behavior: smooth;
  }

  .mobile-filter-header {
    display: none;
  }

  /* Responsive layout overrides */
  @media (max-width: 1100px) {
    .portfolio-container { 
      flex-direction: column; 
      padding-top: 170px !important; 
      padding-left: 4% !important; 
    }
    .filter-sidebar { 
      width: 100% !important; 
      position: relative !important; 
      left: auto !important; 
      top: auto !important; 
      height: auto !important; 
      padding-top: 0 !important; 
      margin-bottom: 30px; 
      transition: none !important;
      transform: none !important;
    }
    .filter-sidebar:hover, .filter-sidebar.init-reveal {
      width: 100% !important;
    }
    .filter-sticky { 
      opacity: 1 !important; 
      visibility: visible !important; 
      width: 100% !important; 
      position: relative !important; 
      top: auto !important; 
      transition: none !important;
    }
    .filter-sidebar:hover .filter-sticky, .filter-sidebar.init-reveal .filter-sticky {
      opacity: 1 !important;
      visibility: visible !important;
    }
    
    .mobile-filter-header {
      display: inline-flex;
      align-items: center;
      cursor: pointer;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      color: #1a1a1a;
      padding-bottom: 0.5rem;
      border-bottom: none; /* Removed default heavy bottom border */
      margin-bottom: 1rem;
      user-select: none;
    }
    .mobile-filter-header .toggle-arrow {
      margin-left: 0.5rem;
      font-size: 0.6rem;
    }
    
    .filter-list {
      display: none;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 20px;
      margin-top: 0.5rem;
      border-bottom: 1px solid #eee;
      padding-bottom: 1.5rem;
    }
    .filter-list.is-open {
      display: flex;
    }
    
    .filter-item::before { display: none; }
    .filter-item { 
      padding-left: 0 !important; 
      color: #444; /* Darker text color (improved readability) */
      border-bottom: 1px solid transparent;
      padding-bottom: 2px;
      transition: color 0.3s, border-color 0.3s;
    }
    .filter-item:hover, .filter-item.active {
      color: #000;
    }
    .filter-item.active {
      border-bottom: 1px solid rgba(0, 0, 0, 0.3) !important; /* Faint active underline */
    }
    
    .masonry-infinite-wrapper { 
      margin-left: 0 !important; 
      transition: none !important;
    }
    .filter-sidebar:hover + .masonry-infinite-wrapper, 
    .filter-sidebar.init-reveal + .masonry-infinite-wrapper { 
      margin-left: 0 !important; 
    }
    
    .grid-track { grid-template-columns: repeat(2, 1fr); row-gap: 120px; }
    .project-card.colspan-3, .project-card.colspan-2 { grid-column: span 1 !important; }
    .grid-spacer { display: none !important; }
    .space-tight, .space-medium, .space-wide { padding: 0; margin-top: 0; }
  }
  @media (max-width: 768px) { 
    .grid-track { grid-template-columns: 1fr; row-gap: 80px; } 
  }
</style>
