---
import { ViewTransitions } from 'astro:transitions';
import SpeedInsights from '@vercel/speed-insights/astro';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
  activeTab?: 'projects' | 'about' | 'lab' | 'contact';
  subTab?: 'modular' | 'solution';
  ogImage?: string;
}

const {
  title = "MMO ARCHITECTS | 주식회사 엠엠오건축사사무소",
  description = "물질과 방법론의 심도 있는 결합을 통해 공간의 예술 질서를 확립하는 KIRA 인증 건축사사무소. Architecture, Value-up, Branding 총괄.",
  activeTab,
  subTab,
  ogImage = "/assets/logo.png"
} = Astro.props;

// Determine location text based on tab
const isLab = activeTab === 'lab';
const locationText = isLab ? "LABORATORY" : "SEOUL, KR";
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  
  <!-- OpenGraph Metadata for Social Link Sharing (KakaoTalk, Slack, Facebook) -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="MMO ARCHITECTS" />

  <meta name="naver-site-verification" content="네이버인증코드입력" />
  <meta name="google-site-verification" content="구글인증코드입력" />
  <meta name="msvalidate.01" content="0292E780AD9FBDCDBDF6B974F4619B25" />

  <!-- Pretendard WebFont -->
  <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" />

  <ViewTransitions />

  <style is:global>
    /* 1. Global Reset & Scrollbars */
    ::-webkit-scrollbar { display: none; }
    * { -ms-overflow-style: none; scrollbar-width: none; }
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Pretendard', sans-serif; }
    
    body { 
      background-color: #F5F4F0; color: #1a1a1a; 
      overflow-x: hidden; min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }
    a { color: #000; text-decoration: none; }
    body.modal-open { overflow: hidden; }

    /* 2. Common GNB Styles */
    header {
      position: fixed; top: 0; left: 0; width: 100%;
      padding: 2.5rem 3rem; display: flex; justify-content: space-between; align-items: center;
      background: rgba(245, 244, 240, 0.92); z-index: 1000;
    }
    .logo { line-height: 1; }
    .logo-link {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      line-height: 1.2;
    }
    .logo-title {
      font-size: 1.1rem;
      font-weight: bold;
      letter-spacing: 0.05em;
      color: #000;
    }
    .logo-sub {
      font-size: 0.55rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #888;
      font-weight: 500;
      margin-top: 0.15rem;
    }
    .nav-menu { 
      display: flex; gap: 3rem; position: absolute; left: 50%; top: 50%; 
      transform: translate(-50%, -50%); align-items: center; 
      transition: opacity 0.35s ease, max-height 0.35s ease, margin-top 0.35s ease, visibility 0.35s;
      max-height: 40px;
    }
    .nav-menu a, .nav-menu .nav-lab-link { 
      font-size: 0.85rem; letter-spacing: 0.1em; font-weight: 600; color: #888; 
      display: flex; align-items: center; line-height: 1; 
    }
    .nav-menu span.nav-lab-link {
      cursor: default;
    }
    .nav-menu a:hover, .nav-menu a.active, .nav-menu .nav-lab-link:hover, .nav-menu .nav-lab-link.active { color: #000; }
    .nav-right { font-size: 0.7rem; color: #ccc; letter-spacing: 0.1em; line-height: 1; display: flex; align-items: center; }

    /* LNB Hover dropdown */
    .nav-item-wrapper {
      position: relative;
      display: flex;
      align-items: center;
    }
    .nav-lab-link {
      display: flex;
      align-items: center;
      line-height: 1;
    }
    .lnb-hover-menu {
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%) translateY(10px);
      display: flex;
      gap: 1.5rem;
      opacity: 0;
      visibility: hidden;
      transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
      white-space: nowrap;
      padding-top: 1rem;
      z-index: 1010;
    }
    .nav-item-wrapper:hover .lnb-hover-menu {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(0);
    }
    .nav-item-wrapper.active-parent .lnb-hover-menu {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(0);
    }
    .lnb-hover-item {
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      font-weight: 600;
      color: #888 !important;
      display: flex;
      align-items: center;
      line-height: 1;
    }
    .lnb-hover-item.active, .lnb-hover-item:hover {
      color: #000 !important;
    }

    /* 3. Common Footer Styles */
    .mmo-footer {
      background-color: #F5F4F0;
      padding: 10rem 4% 4rem 4%;
      max-width: 1900px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1.51fr 1fr;
      gap: 4rem;
      border-top: 1px solid #e5e4e0;
    }

    /* 4. Responsive Queries */
     @media (max-width: 1100px) {
      header {
        padding: 1.5rem 2rem;
        flex-wrap: wrap;
        justify-content: space-between;
        transition: padding 0.35s ease;
      }
      header.scrolled {
        padding-bottom: 1.5rem;
      }
      .logo { order: 1; }
      .nav-right { order: 2; font-size: 0.65rem; }
      .nav-menu {
        order: 3; width: 100%; position: static; transform: none;
        margin-top: 1.2rem; justify-content: center; gap: 1.8rem;
      }
      header.scrolled .nav-menu {
        opacity: 0;
        visibility: hidden;
        max-height: 0;
        margin-top: 0;
        pointer-events: none;
        overflow: hidden;
      }
    }
  </style>
  <Analytics />
</head>
<body>
  <!-- GNB Header -->
  <header>
    <div class="logo">
      <a href="/" class="logo-link">
        <span class="logo-title">MMO ARCHITECTS</span>
        <span class="logo-sub">Design lab</span>
      </a>
    </div>
    <div class="nav-menu">
      <a href="/projects" class={activeTab === 'projects' ? 'active' : ''}>PROJECTS</a>
      <div class={`nav-item-wrapper ${activeTab === 'lab' ? 'active-parent' : ''}`}>
        <a href="/lab-modular" class={`nav-lab-link ${activeTab === 'lab' ? 'active' : ''}`}>LAB — EDITIONS</a>
        <div class="lnb-hover-menu">
          <a href="/lab-modular" class={`lnb-hover-item ${subTab === 'modular' ? 'active' : ''}`}>MODULAR</a>
          <a href="/lab-solution" class={`lnb-hover-item ${subTab === 'solution' ? 'active' : ''}`}>SOLUTION</a>
        </div>
      </div>
      <a href="/about" class={activeTab === 'about' ? 'active' : ''}>ABOUT</a>
      <a href="/contact" class={activeTab === 'contact' ? 'active' : ''}>CONTACT</a>
    </div>
    <div class="nav-right">{locationText}</div>
  </header>

  <!-- Main Slot Content -->
  <slot />

  <!-- Global Footer (Only rendered if footer is not visually hidden by page styles) -->
  <footer class="mmo-footer">
    <div style="display: flex; flex-direction: column; gap: 1.2rem;">
      <div>
        <h4 style="font-size: 1.1rem; font-weight: bold; letter-spacing: 0.05em; margin-bottom: 1rem;">MMO ARCHITECTS</h4>
        <p style="font-size: 0.9rem; color: #555; max-width: 480px; line-height: 1.7; word-break: keep-all;">엠엠오건축사사무소는 물질(Matter)과 방법론(Method)의 심도 있는 결합을 통해 공간의 최종적인 예술 질서(Order)를 확립합니다.</p>
      </div>
      <div style="font-size: 9px; color: #aaa; line-height: 1.6; letter-spacing: 0.02em; font-weight: 400;">
        주식회사 엠엠오건축사사무소 <br>
        서울특별시 강서구, 대한민국
      </div>
    </div>
    <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 1.2rem; text-align: right;">
      <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.8rem;">
        <div style="font-size: 0.75rem; letter-spacing: 0.15em; color: #8c8a85; font-weight: 600; text-transform: uppercase;">Direct Contact</div>
        <div style="font-size: 0.9rem; font-weight: 400; line-height: 1.6; display: flex; flex-direction: column; gap: 0.4rem; align-items: flex-end;">
          <a href="mailto:official@mmoarchitects.com" style="transition: color 0.4s;" onmouseover="this.style.color='#8c8a85'" onmouseout="this.style.color='#1a1a1a'">official@mmoarchitects.com</a>
          <a href="https://instagram.com/mmoarchitects" target="_blank" style="transition: color 0.4s;" onmouseover="this.style.color='#8c8a85'" onmouseout="this.style.color='#1a1a1a'">@mmoarchitects</a>
        </div>
      </div>
      <div style="font-size: 9px; color: #888; letter-spacing: 0.02em;">
        © 2026 MMO Architects. All rights reserved.
      </div>
    </div>
  </footer>

  <script>
    function initScrollHeader() {
      const header = document.querySelector('header');
      if (!header) return;
      
      let lastScrollY = window.scrollY;
      
      const handleScroll = () => {
        const currentScrollY = window.scrollY;
        
        if (currentScrollY <= 20) {
          // Always show when near the top
          header.classList.remove('scrolled');
        } else if (currentScrollY > lastScrollY) {
          // Scrolling down: hide 2nd row
          header.classList.add('scrolled');
        } else {
          // Scrolling up: show 2nd row
          header.classList.remove('scrolled');
        }
        
        lastScrollY = currentScrollY;
      };
      
      window.addEventListener('scroll', handleScroll);
      // Run once initially to check initial state
      handleScroll();

      // Clean up event listener when leaving/transitioning pages in Astro
      document.addEventListener('astro:before-swap', () => {
        window.removeEventListener('scroll', handleScroll);
      }, { once: true });
    }

    // Run on initial load and subsequent navigation page transitions
    document.addEventListener('astro:page-load', initScrollHeader);
  </script>
  <SpeedInsights />
</body>
</html>
